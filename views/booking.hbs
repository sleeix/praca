              </div>

              <div>
                <label for="email" class="block mb-2 font-medium">Adres email</label>
                <input type="email" name="email" placeholder="example@gmail.com" required 
                class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 outline-1 outline-gray-300 
                placeholder:text-gray-400 focus:outline-2 focus:outline-indigo-600"/>
              </div>
              
              <div>
                <label for="phone" class="block mb-2 font-medium">Numer telefonu</label>
                <input type="text" name="phone" pattern="[0-9]{9}" maxlength="9" inputmode="numeric" placeholder="123456789" required 
                class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 outline-1 outline-gray-300 
                placeholder:text-gray-400 focus:outline-2 focus:outline-indigo-600"/>
              </div>

              <div>
                <label for="service" class="block mb-2 font-medium">Rodzaj usługi</label>
                <select name="service" required 
                class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 outline-1 outline-gray-300 
