    </div>
  </div>
</div>

<script>
  const timeSelect = document.getElementById('time');
  const dateInput = document.getElementById('date');

  function openDateSheet() {
    document.getElementById('dateSheet').classList.remove('hidden');
  }

  function closeDateSheet() {
    document.getElementById('dateSheet').classList.add('hidden');
  }

  function isSalonClosedNow() {
    const now = new Date();
    const day = now.getDay();
    const hour = now.getHours();

    if (day === 0) return true;
    if (day === 6) return hour < 10 || hour >= 15;
    return hour < 9 || hour >= 17;
  }

  document.addEventListener('DOMContentLoaded', () => {

    const isMobile = window.innerWidth < 768;

    flatpickr("#date", {
      locale: flatpickr.l10ns.pl,
      dateFormat: "Y-m-d",
      minDate: "today",
      disableMobile: true,
      clickOpens: !isMobile,
      disable: [
        function (date) {
          if (date.getDay() === 0) return true;

          const today = new Date();
          if (
            date.toDateString() === today.toDateString() &&
            isSalonClosedNow()
          ) return true;

          return false;
        }
      ],
      onChange(selectedDates) {
        timeSelect.disabled = false;
        handleTimeFiltering(selectedDates[0]);
      }
    });

    flatpickr("#mobileDatePicker", {
      locale: flatpickr.l10ns.pl,
      dateFormat: "Y-m-d",
      minDate: "today",
      inline: true,
      disable: [
        function (date) {
          if (date.getDay() === 0) return true;

          const today = new Date();
          if (
            date.toDateString() === today.toDateString() &&
            isSalonClosedNow()
          ) return true;

          return false;
        }
      ],
      onChange(selectedDates, dateStr) {
        dateInput.value = dateStr;
        timeSelect.disabled = false;
        closeDateSheet();
        handleTimeFiltering(selectedDates[0]);
      }
    });

    async function handleTimeFiltering(selectedDate) {
      const day = selectedDate.getDay();
      const now = new Date();
      const formattedDate = selectedDate.toISOString().split('T')[0];

      const response = await fetch(`/booking/booked-times?date=${formattedDate}`);
      const bookedTimes = await response.json();

      Array.from(timeSelect.options).forEach(option => {
        if (!option.value) return;

        const hour = parseInt(option.value);
        let hide = false;

        if (day === 6) hide = hour < 10 || hour >= 15;
        else hide = hour < 9 || hour >= 17;

        if (selectedDate.toDateString() === now.toDateString()) {
          hide = hide || hour <= now.getHours();
        }

        if (bookedTimes.includes(option.value)) {
          hide = true;
        }

        option.disabled = hide;
        option.style.display = hide ? "none" : "block";
      });

      if (dateInput.value) {
        const existingDate = new Date(dateInput.value);
        handleTimeFiltering(existingDate);
      }

      dateInput.addEventListener('input', () => {
        if (!dateInput.value) {
          timeSelect.disabled = true;
          timeSelect.value = '';
        }
      });
    }
  });
</script> --}}