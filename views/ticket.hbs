<div class="min-h-screen bg-neutral-100">
  <div class="max-w-6xl mx-auto px-2 py-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

      {{> dashboardSidebar activeTab="messages"}}

      <div class="md:col-span-3 flex flex-col gap-4">

        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 px-6 py-4 flex items-center gap-3">
          <a href="/messages" class="text-neutral-400 hover:text-neutral-700 transition">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-bold text-neutral-900 truncate">{{ticket.subject}}</p>
            <p class="text-xs text-neutral-400 mt-0.5">Wątek #{{ticket.id}}</p>
          </div>
          {{#if (eq ticket.status "open")}}
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-semibold shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block"></span> Oczekuje
          </span>
          {{else if (eq ticket.status "answered")}}
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-green-50 text-green-600 text-xs font-semibold shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span> Odpowiedziano
          </span>
          {{else}}
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-500 text-xs font-semibold shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-neutral-400 inline-block"></span> Zamknięty
          </span>
          {{/if}}
        </div>

        <div class="flex flex-col gap-3 bg-white rounded-2xl border border-neutral-200 p-4">
          {{#each messages}}
          <div class="flex {{#if (eq sender 'user')}}justify-end{{else}}justify-start{{/if}}">
            <div class="max-w-[80%]">
              {{#if (eq sender 'admin')}}
              <div class="flex items-center gap-2 mb-1">
                <div class="w-6 h-6 rounded-full bg-amber-400 flex items-center justify-center text-xs font-bold text-neutral-900">A</div>
                <span class="text-xs text-neutral-500 font-semibold">Maestro Barber</span>
              </div>
              {{/if}}
              <div class="px-4 py-3 rounded-2xl text-sm leading-relaxed break-all overflow-hidden
                {{#if (eq sender 'user')}}
                  bg-amber-400 text-neutral-900 rounded-br-sm
                {{else}}
                  bg-white border border-neutral-200 text-neutral-800 rounded-bl-sm shadow-sm
                {{/if}}">
                {{message}}
              </div>
              <p class="text-xs text-neutral-400 mt-1 {{#if (eq sender 'user')}}text-right{{/if}}">
                {{formatDateTimePL created_at}}
              </p>
            </div>
          </div>
          {{/each}}
        </div>

        {{#if (eq ticket.status "closed")}}
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-4 text-center text-sm text-neutral-400">
          Ten wątek jest zamknięty. Jeśli masz kolejne pytanie —
          <a href="/contact" class="text-amber-600 hover:underline font-medium">napisz nową wiadomość</a>.
        </div>
        {{else}}
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-4">
          <form action="/messages/{{ticket.id}}/reply" method="POST" class="flex gap-3 items-end">
            <textarea
              name="message"
              rows="1"
              required
              placeholder="Napisz odpowiedź..."
              class="flex-1 rounded-xl border border-neutral-200 px-3.5 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-transparent transition resize-none"
            ></textarea>
            <button type="submit"
              class="px-4 py-2.5 rounded-xl bg-amber-400 hover:bg-amber-300 text-neutral-900 text-sm font-bold transition shrink-0">
              Wyślij
            </button>
          </form>
        </div>
        {{/if}}

      </div>
    </div>
  </div>
</div>