<div class="min-h-screen bg-neutral-100">
  <div class="max-w-6xl mx-auto px-2 py-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

      {{> dashboardSidebar activeTab="messages"}}

      <div class="md:col-span-3">
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200">

          <div class="px-6 py-5 border-b border-neutral-100 flex items-center justify-between">
            <div>
              <h1 class="text-lg font-bold text-neutral-900">Wiadomości</h1>
              <p class="text-xs text-neutral-500 mt-0.5">Twoja korespondencja z salonem</p>
            </div>
            <a href="/contact"
              class="px-4 py-2 rounded-xl bg-amber-400 hover:bg-amber-300 text-neutral-900 text-xs font-bold transition">
              + Nowa wiadomość
            </a>
          </div>

          {{#if tickets.length}}
          <div class="divide-y divide-neutral-100 overflow-hidden">
            {{#each tickets}}
            <div class="flex items-center hover:bg-neutral-50 transition group first:rounded-t-2xl last:rounded-b-2xl">
              <a href="/messages/{{id}}" class="flex-1 block p-5">
                <div class="flex items-start gap-3">

                  <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-sm font-bold
                  {{#if (eq status 'answered')}} bg-green-100 text-green-700
                  {{else if (eq status 'closed')}} bg-neutral-100 text-neutral-500
                  {{else}} bg-blue-50 text-blue-600 {{/if}}">
                    {{#if (eq status 'answered')}}
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                      stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {{else if (eq status 'closed')}}
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                      stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    {{else}}
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                      stroke-width="2">
                      <circle cx="12" cy="12" r="10" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                    </svg>{{/if}}
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <p class="text-sm font-semibold text-neutral-900 truncate">
                        {{#if subject}}{{subject}}{{else}}Wątek #{{id}}{{/if}}
                      </p>
                    </div>
                    {{#if last_message}}
                    {{/if}}
                    {{#if admin_replies}}
                    <p class="text-xs text-neutral-400 mt-1">
                      {{admin_replies}} {{#if (eq admin_replies 1)}}odpowiedź{{else}}odpowiedzi{{/if}} od salonu
                    </p>
                    {{else}}
                    <p class="text-xs text-neutral-400 mt-1">
                      Brak odpowiedzi
                    </p>
                    {{/if}}
                  </div>

                </div>
              </a>

              <form action="/messages/{{id}}/delete" method="POST" class="pr-4 shrink-0">
                <button type="submit" title="Usuń wątek"
                  class="p-2 rounded-xl text-neutral-600 hover:text-red-500 hover:bg-red-50 transition opacity-0 group-hover:opacity-100">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="py-16 text-center">
            <p class="text-neutral-400 text-sm">Nie masz jeszcze żadnych wiadomości</p>
          </div>
          {{/if}}

        </div>
      </div>

    </div>
  </div>
</div>