<aside class="md:col-span-1">
  <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 p-4">

    <p class="text-xs uppercase tracking-widest text-neutral-400 font-semibold mb-4 px-2">Konto</p>

    <nav class="space-y-1">

      <a href="/dashboard"
        class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium transition
          {{#if (eq activeTab 'profile')}} bg-neutral-100 text-neutral-700 font-semibold {{else}} text-neutral-500 hover:bg-neutral-100 {{/if}}">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Profil
      </a>

      <a href="/appointments"
        class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium transition
          {{#if (eq activeTab 'appointments')}} bg-neutral-100 text-neutral-700 font-semibold {{else}} text-neutral-500 hover:bg-neutral-100 {{/if}}">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
          <line x1="16" x2="16" y1="2" y2="6"/>
          <line x1="8" x2="8" y1="2" y2="6"/>
          <line x1="3" x2="21" y1="10" y2="10"/>
          <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01M16 18h.01"/>
        </svg>
        Wizyty
      </a>

      {{#if user}}
      <a href="/messages"
        class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium transition
          {{#if (eq activeTab 'messages')}} bg-neutral-100 text-neutral-700 font-semibold {{else}} text-neutral-500 hover:bg-neutral-100 {{/if}}">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Wiadomości
      </a>
      {{/if}}

      <a href="#" onclick="openDeleteModal(); return false;"
        class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium text-red-500 hover:bg-red-50 transition">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Usuń konto
      </a>

      {{#if (eq user.role "admin")}}
      <div class="border-t border-neutral-100 my-2"></div>

      <h3 class="text-xs uppercase tracking-widest text-neutral-400 font-semibold mb-4 px-2">Panel admina</h3>

      <a href="/admin"
        class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium transition
          {{#if (eq activeTab 'admin')}} bg-blue-50 text-blue-600 font-semibold {{else}} text-blue-400 hover:bg-blue-50 {{/if}}">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="18" cy="15" r="3"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M10 15H6a4 4 0 0 0-4 4v2"/>
          <path d="m21.7 16.4-.9-.3m-6.5-2.5-.9-.3m1.4 4.8.3-.9m2.5-6.5.3-.9m.5 6.5-.4-1m-3-5.4-.4-1m-2.5 4.3 1-.4m6.4-2.5 1-.4"/>
        </svg>
        Wizyty
      </a>

      <a href="/admin/messages"
        class="flex items-center justify-between gap-2.5 rounded-xl px-3 py-2.5 text-sm font-medium transition
          {{#if (eq activeTab 'admin-messages')}} bg-blue-50 text-blue-600 font-semibold {{else}} text-blue-400 hover:bg-blue-50 {{/if}}">
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Wiadomości
        </div>
      </a>

      {{/if}}

    </nav>
  </div>
</aside>
