<header class="bg-neutral-800">
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />

  <div class="mx-auto max-w-6xl px-4">
    <div class="flex h-16 items-center justify-between">

      <div class="flex items-center">
        <a href="/" class="flex items-center gap-2.5 shrink-0">
          <div class="w-8 h-8 bg-amber-400 rounded-lg flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#171717" stroke-width="2.2" stroke-linecap="round">
              <path d="M6 3L3 8l9 13L21 8l-3-5z"/>
              <path d="M3 8h18M6 3l3 5M18 3l-3 5"/>
            </svg>
          </div>
          <div class="leading-none">
            <span class="block text-white font-bold text-base tracking-wide">Maestro</span>
            <span class="block text-amber-400 text-[9px] uppercase tracking-[0.2em] font-medium">Barber</span>
          </div>
        </a>
      </div>

      <nav class="hidden md:block">
        <ul class="flex items-center gap-8 text-sm">

          <li>
            <a href="/" class="text-neutral-400 hover:text-white transition">
              Strona główna
            </a>
          </li>

          <li>
            <a href="/service" class="text-neutral-400 hover:text-white transition">
              Usługi
            </a>
          </li>

          <li>
            <a href="/contact" class="text-neutral-400 hover:text-white transition">
              Kontakt
            </a>
          </li>

          {{#if user}}
          <li>
            <a href="/dashboard"
              class="text-neutral-300 hover:text-white font-medium transition flex flex-row gap-2 items-center">
              <svg xmlns="http://www.w3.org/2000/svg" height="30px" viewBox="0 -960 960 960" width="30px"
                fill="#e3e3e3">
                <path
                  d="M234-276q51-39 114-61.5T480-360q69 0 132 22.5T726-276q35-41 54.5-93T800-480q0-133-93.5-226.5T480-800q-133 0-226.5 93.5T160-480q0 59 19.5 111t54.5 93Zm246-164q-59 0-99.5-40.5T340-580q0-59 40.5-99.5T480-720q59 0 99.5 40.5T620-580q0 59-40.5 99.5T480-440Zm0 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q53 0 100-15.5t86-44.5q-39-29-86-44.5T480-280q-53 0-100 15.5T294-220q39 29 86 44.5T480-160Zm0-360q26 0 43-17t17-43q0-26-17-43t-43-17q-26 0-43 17t-17 43q0 26 17 43t43 17Zm0-60Zm0 360Z" />
              </svg>
              Konto
            </a>
          </li>

          <li>
            <a href="/auth/logout" class="rounded-lg bg-red-600/90 px-4 py-2 text-sm font-medium text-white">
              Wyloguj
            </a>
          </li>

          {{else}}
          <li>
            <a href="/auth/login"
              class="bg-neutral-700 rounded-lg border border-neutral-700 px-4 py-2 text-sm text-neutral-100 hover:bg-neutral-800 hover:text-white transition">
              Zaloguj się
            </a>
          </li>

          <li>
            <a href="/auth/register"
              class="rounded-lg bg-neutral-100 px-4 py-2 text-sm font-semibold text-neutral-900 hover:bg-neutral-700 hover:text-white transition">
              Utwórz konto
            </a>
          </li>
          {{/if}}
        </ul>
      </nav>

      <label for="mobile-menu-toggle"
        class="block md:hidden cursor-pointer rounded-lg border border-neutral-700 p-2 text-neutral-300 hover:bg-neutral-800 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
          stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <div
    class="max-h-0 overflow-hidden peer-checked:max-h-96 md:hidden bg-neutral-900 border-t border-neutral-800 transition-all duration-300">

    <nav>
      <ul class="flex flex-col gap-4 p-4 text-sm text-center">

        <li>
          <a href="/" class="text-neutral-400 hover:text-white transition">
            Strona główna
          </a>
        </li>

        <li>
          <a href="/service" class="text-neutral-400 hover:text-white transition">
            Usługi
          </a>
        </li>

        <li>
          <a href="/contact" class="block text-neutral-400 hover:text-white transition">
            Kontakt
          </a>
        </li>

        {{#if user}}
        <li>
          <a href="/dashboard"
            class="text-neutral-300 hover:text-white font-medium transition flex flex-row gap-2 items-center justify-center">
            Konto
          </a>
        </li>

        <li>
          <a href="/auth/logout"
            class="block justify-center mx-auto rounded-lg bg-red-600 py-2 text-center text-white max-w-sm">
            Wyloguj
          </a>
        </li>

        {{else}}
        <li>
          <a href="/auth/login"
            class="block justify-center mx-auto rounded-lg border border-neutral-700 px-4 py-2 text-center text-neutral-300 hover:bg-neutral-800 hover:text-white transition max-w-sm">
            Zaloguj się
          </a>
        </li>

        <li>
          <a href="/auth/register"
            class="block justify-center mx-auto rounded-lg bg-neutral-100 px-4 py-2 text-center font-semibold text-neutral-900 hover:bg-white transition max-w-sm">
            Utwórz konto
          </a>
        </li>
        {{/if}}
      </ul>
    </nav>
  </div>
</header>