<div class="min-h-screen bg-neutral-100">
  <div class="max-w-6xl mx-auto px-2 py-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

      {{> dashboardSidebar activeTab="profile"}}

      <div class="md:col-span-3 space-y-5">
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200">

          <div class="px-6 py-5 border-b border-neutral-100">
            <h2 class="text-lg font-bold text-neutral-900">Dane osobowe</h2>
            <p class="text-xs text-neutral-500 mt-0.5">Zmień swoją nazwę użytkownika oraz adres email.</p>
          </div>

          <div class="px-6 py-6 space-y-6">

            <form action="/dashboard/profile" method="POST" class="space-y-4">
              <input type="hidden" name="action" value="update-email">
              <div>
                <label class="block mb-1.5 text-sm font-semibold text-neutral-700">Email</label>
                <input type="email" name="email" value="{{user.email}}"
                  class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition">
              </div>
              <button class="bg-amber-400 hover:bg-amber-300 text-neutral-900 text-sm font-bold px-5 py-2 rounded-xl transition">
                Zmień email
              </button>
            </form>

            <div class="border-t border-neutral-100"></div>

            <form action="/dashboard/profile" method="POST" class="space-y-4">
              <input type="hidden" name="action" value="update-name">
              <div>
                <label class="block mb-1.5 text-sm font-semibold text-neutral-700">Nazwa użytkownika</label>
                <input type="text" name="name" value="{{user.name}}"
                  class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition">
              </div>
              <button class="bg-amber-400 hover:bg-amber-300 text-neutral-900 text-sm font-bold px-5 py-2 rounded-xl transition">
                Zmień nazwę
              </button>
            </form>

          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200">
          <div class="px-6 py-5 border-b border-neutral-100">
            <h2 class="text-base font-bold text-neutral-900">Zmiana hasła</h2>
            <p class="text-xs text-neutral-500 mt-0.5">Zaktualizuj swoje hasło przypisane do konta.</p>
          </div>

          <div class="px-6 py-6">
            <form action="/dashboard/profile" method="POST" class="space-y-4">
              <input type="hidden" name="action" value="update-password">

              <div>
                <label class="block mb-1.5 text-sm font-semibold text-neutral-700">Aktualne hasło</label>
                <input type="password" name="oldPassword" required
                  class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition">
              </div>

              <div>
                <label class="block mb-1.5 text-sm font-semibold text-neutral-700">Nowe hasło</label>
                <input type="password" name="newPassword" required
                  class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition">
              </div>

              <div>
                <label class="block mb-1.5 text-sm font-semibold text-neutral-700">Potwierdź nowe hasło</label>
                <input type="password" name="newPasswordConfirm" required
                  class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-2.5 text-sm text-neutral-900 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition">
              </div>

              <button class="bg-amber-400 hover:bg-amber-300 text-neutral-900 text-sm font-bold px-5 py-2 rounded-xl transition">
                Zmień hasło
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
