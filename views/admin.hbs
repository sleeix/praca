<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pl.js"></script>

<div class="min-h-screen bg-neutral-100">
  <div class="max-w-6xl mx-auto px-2 py-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

      {{> dashboardSidebar activeTab="admin"}}

      <div class="md:col-span-3">
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200">

          <!-- Nagłówek -->
          <div class="px-6 py-5 border-b border-neutral-100 flex items-center justify-between gap-4">
            <div>
              <h1 class="text-lg font-bold text-neutral-900">Panel admina</h1>
              <p class="text-xs text-neutral-500 mt-0.5">Zarządzaj wizytami w salonie</p>
            </div>

            <form method="GET" action="/admin" id="dateForm" class="flex items-center gap-2">
              <input type="hidden" name="status" value="{{currentStatus}}">
              <input type="hidden" name="date" id="dateHidden" value="{{selectedDate}}">

              {{#if selectedDate}}
              <a href="?status={{currentStatus}}"
                class="p-2 rounded-xl hover:bg-red-50 text-red-400 transition" title="Wyczyść filtr">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </a>
              {{else}}
              <button type="button" id="calendarBtn" onclick="openDateSheet()"
                class="p-2 rounded-xl hover:bg-neutral-100 transition text-neutral-500" title="Filtruj po dacie">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </button>
              {{/if}}
              <input id="datePicker" type="text" class="hidden">
            </form>
          </div>

          <!-- Filtry statusu -->
          <div class="px-6 py-4 flex gap-2 flex-wrap border-b border-neutral-100 justify-center">
            <a href="/admin?status=active"
              class="rounded-xl px-4 py-1.5 text-xs font-semibold transition
                {{#if (eq currentStatus 'active')}} bg-amber-400 text-neutral-900 {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              Nadchodzące ({{counts.activeCount}})
            </a>
            <a href="/admin?status=completed"
              class="rounded-xl px-4 py-1.5 text-xs font-semibold transition
                {{#if (eq currentStatus 'completed')}} bg-green-500 text-white {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              Zakończone ({{counts.completedCount}})
            </a>
            <a href="/admin?status=cancelled"
              class="rounded-xl px-4 py-1.5 text-xs font-semibold transition
                {{#if (eq currentStatus 'cancelled')}} bg-red-500 text-white {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              Odwołane ({{counts.cancelledCount}})
            </a>
          </div>

          <!-- Lista wizyt -->
          {{#if bookings.length}}
          <div class="p-4 space-y-3">
            {{#each bookings}}
            <div class="bg-neutral-50 rounded-2xl border border-neutral-200 p-5 hover:shadow-sm transition">

              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">

                <div class="flex gap-4">
                  <div class="w-11 h-11 rounded-full bg-neutral-200 overflow-hidden shrink-0">
                    <img src="/images/avatar.png" class="w-full h-full object-cover"/>
                  </div>
                  <div>
                    <p class="text-xs text-neutral-400 flex items-center gap-1 mb-1">
                      📍 Bychawska 8/2, 24-200 Bełżyce
                    </p>
                    <p class="text-sm font-bold text-neutral-900">{{fullname}}</p>
                    <p class="text-xs text-neutral-500 mt-0.5">{{service}}</p>
                    <div class="flex flex-wrap gap-3 mt-2">
                      <p class="text-xs text-neutral-400">📞 (+48) {{phone}}</p>
                      <p class="text-xs text-neutral-400 break-all">✉ {{email}}</p>
                    </div>
                  </div>
                </div>

                <div class="text-left sm:text-right shrink-0">
                  <p class="text-sm font-semibold text-neutral-900">{{formatDatePL date}}</p>
                  <p class="text-xs text-neutral-400 mt-0.5">{{formatTimeHM time}}</p>
                </div>

              </div>

              {{#if (eq status "active")}}
              <div class="mt-4 pt-4 border-t border-neutral-200 flex justify-end">
                <button onclick="openCancelModal({{id}})"
                  class="px-4 py-1.5 rounded-xl bg-red-600 hover:bg-red-500 text-white text-xs font-semibold transition">
                  Odwołaj wizytę
                </button>
              </div>
              {{/if}}

            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="py-16 text-center text-neutral-400 text-sm">
            Brak wizyt w tej kategorii
          </div>
          {{/if}}

        </div>
      </div>

    </div>
  </div>
</div>

<!-- Mobile date sheet -->
<div id="dateSheet" class="fixed inset-0 z-50 hidden md:hidden">
  <div class="absolute inset-0 bg-black/60" onclick="closeDateSheet()"></div>
  <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-neutral-200 rounded-t-2xl">
    <div class="flex justify-between items-center p-4 border-b border-neutral-100">
      <span class="text-sm font-semibold text-neutral-700">Wybierz datę</span>
      <button onclick="closeDateSheet()" class="text-neutral-400 hover:text-neutral-700">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <input id="mobileDatePicker" type="text" class="hidden">
  </div>
</div>

<script>
  function openCancelModal(bookingId) {
    const modal = document.getElementById('cancelModal');
    const form = document.getElementById('cancelForm');
    form.action = `/admin/cancel-booking/${bookingId}`;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  function closeCancelModal() {
    const modal = document.getElementById('cancelModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
</script>
<script src="/js/dateFilter.js"></script>
<script>
  initDateFilter({ mode: "admin", submitType: "form" });
</script>
