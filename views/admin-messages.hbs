<div class="min-h-screen bg-neutral-100">
  <div class="max-w-6xl mx-auto px-2 py-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">

      {{> dashboardSidebar activeTab="admin-messages"}}

      <div class="md:col-span-3">
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200">

          <div class="px-6 py-5 border-b border-neutral-100">
            <h1 class="text-lg font-bold text-neutral-900">Wiadomości klientów</h1>
            <p class="text-xs text-neutral-500 mt-0.5">Zgłoszenia i pytania klientów</p>
          </div>

          <div class="px-6 py-4 flex gap-2 flex-wrap border-b border-neutral-100 justify-center">
            <a href="/admin/messages?status=open"
              class="inline-flex items-center gap-1.5 rounded-xl px-4 py-1.5 text-xs font-semibold transition
              {{#if (eq currentStatus 'open')}} bg-blue-500 text-white {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
              </svg>
              Oczekujące
              {{#if openCount}}
              <span
                class="{{#if (eq currentStatus 'open')}}bg-white text-blue-600{{else}}bg-blue-500 text-white{{/if}} rounded-full px-2 py-0.5">{{openCount}}</span>
              {{/if}}
            </a>
            <a href="/admin/messages?status=answered"
              class="inline-flex items-center gap-1.5 rounded-xl px-4 py-1.5 text-xs font-semibold transition
              {{#if (eq currentStatus 'answered')}} bg-green-600 text-white {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Odpowiedziane
            </a>
            <a href="/admin/messages?status=closed"
              class="inline-flex items-center gap-1.5 rounded-xl px-4 py-1.5 text-xs font-semibold transition
              {{#if (eq currentStatus 'closed')}} bg-neutral-600 text-white {{else}} bg-neutral-100 text-neutral-500 hover:bg-neutral-200 {{/if}}">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Zamknięte
            </a>
          </div>

          {{#if tickets.length}}
          <div class="divide-y divide-neutral-100 overflow-hidden">
            {{#each tickets}}
            <div class="flex items-center hover:bg-neutral-50 transition group first:rounded-t-2xl last:rounded-b-2xl">
              <a href="/admin/messages/{{id}}" class="flex-1 block p-5">
                <div class="flex items-start gap-4">
                  <div
                    class="w-9 h-9 rounded-full bg-neutral-200 flex items-center justify-center shrink-0 font-bold text-neutral-600 text-sm uppercase">
                    {{name.[0]}}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-xs font-semibold text-neutral-500">#{{id}} - {{subject}}</span>
                    </div>
                    <p class="text-sm font-medium text-neutral-800 mt-0.5 truncate">
                      {{#if subject}}{{last_message}}{{else}}Wątek #{{id}}{{/if}}
                    </p>
                    {{#if last_message}}
                    {{/if}}
                  </div>
                </div>
              </a>

              <form action="/admin/messages/{{id}}/delete" method="POST" class="pr-4 shrink-0">
                <button type="submit" title="Usuń wątek"
                  class="p-2 rounded-xl text-neutral-600 hover:text-red-500 hover:bg-red-50 transition opacity-0 group-hover:opacity-100">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="py-16 text-center text-neutral-400 text-sm">
            Brak wiadomości w tej kategorii
          </div>
          {{/if}}

        </div>
      </div>

    </div>
  </div>
</div>